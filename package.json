{
  "name": "article-mgmt",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Import/manage/export SumUp item CSVs with a Vite + React + MUI frontend and a better-sqlite3 backend.",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:server\" \"npm:web\"",
    "server": "node server/index.js",
    "web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "user": "node server/scripts/user.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "notistack": "^3.0.2",
    "papaparse": "^5.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "vite": "^8.0.16"
  }
}
