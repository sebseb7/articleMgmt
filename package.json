{
  "name": "article-mgmt",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Import/manage/export SumUp item CSVs with a Vite + React + MUI frontend and a better-sqlite3 backend.",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:server:watch\" \"npm:web\"",
    "dev:test": "concurrently -n server,web -c blue,green \"npm:server:test\" \"npm:web:test\"",
    "server": "node server/index.js",
    "server:watch": "node --watch --watch-path=server server/index.js",
    "server:test": "node server/index.js",
    "web": "vite",
    "web:test": "vite --port 4993",
    "build": "vite build",
    "preview": "vite preview",
    "user": "node server/scripts/user.js",
    "seed": "node server/scripts/seed.js",
    "seed:fresh": "node server/scripts/seed.js --fresh",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "ag-grid-react": "^35.3.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "notistack": "^3.0.2",
    "papaparse": "^5.5.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "vite": "^8.0.16"
  }
}
